{
  "name": "re-vscode",
  "displayName": "RE Language Support",
  "description": "Soporte oficial para el lenguaje RE: coloreado de sintaxis, TypeChecking y autocompletado en tiempo real.",
  "version": "1.0.0",
  "publisher": "re-lang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:re"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "re",
        "aliases": [
          "RE",
          "re"
        ],
        "extensions": [
          ".re"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "re",
        "scopeName": "source.re",
        "path": "./syntaxes/re.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.14.6",
    "@types/vscode": "^1.75.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
